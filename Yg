PosY += 38

-- 🧱 OPCIÓN 3: ATRAVESAR PAREDES
local ParedesActivo = false
local BotonParedes = CrearBoton("🧱 Atravesar paredes (DESACT)", function()
    ParedesActivo = not ParedesActivo
    BotonParedes.Text = ParedesActivo and "✅ Atravesar paredes (ACT)" or "🧱 Atravesar paredes (DESACT)"
    BotonParedes.BackgroundColor3 = ParedesActivo and Color3.fromRGB(40, 160, 80) or Color3.fromRGB(60,60,90)
end)

-- ⚙️ ACTUALIZACIÓN CONTINUA
RunService.RenderStepped:Connect(function()
    -- Obtener personaje
    Caracteristica = Jugador.Character
    if not Caracteristica then return end
    Humanoide = Caracteristica:FindFirstChildWhichIsA("Humanoid")
    Raiz = Caracteristica:FindFirstChild("HumanoidRootPart")
    if not Humanoide or not Raiz then return end

    -- Aplicar velocidad normal
    Humanoide.WalkSpeed = VelocidadValor

    -- ✈️ SISTEMA DE VUELO
    if VolarActivo then
        Humanoide.PlatformStand = true
        local Camara = workspace.CurrentCamera
        local Direccion = Vector3.zero
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then Direccion += Camara.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then Direccion -= Camara.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then Direccion -= Camara.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then Direccion += Camara.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then Direccion += Vector3.yAxis end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then Direccion -= Vector3.yAxis end
        Direccion = Direccion * VelocidadValor
        Raiz.Velocity = Direccion
    else
        Humanoide.PlatformStand = false
    end

    -- 🧱 ATRAVESAR PAREDES
    if ParedesActivo then
        for _, Parte in pairs(Caracteristica:GetDescendants()) do
            if Parte:IsA("BasePart") then Parte.CanCollide = false end
        end
    else
        for _, Parte in pairs(Caracteristica:GetDescendants()) do
            if Parte:IsA("BasePart") then Parte.CanCollide = true end
        end
    end
end)
